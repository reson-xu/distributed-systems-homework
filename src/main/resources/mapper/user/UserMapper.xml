<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.resonxu.seckill.user.infrastructure.mapper.UserMapper">

    <resultMap id="UserResultMap" type="io.github.resonxu.seckill.user.domain.model.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="status" column="status"/>
        <result property="isDeleted" column="is_deleted"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectActiveByUsername" resultMap="UserResultMap">
        SELECT id,
               username,
               password,
               status,
               is_deleted,
               created_at,
               updated_at
        FROM t_user
        WHERE username = #{username}
          AND is_deleted = 0
        LIMIT 1
    </select>

    <insert id="insert" parameterType="io.github.resonxu.seckill.user.domain.model.User"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_user (username, password, status, is_deleted)
        VALUES (#{username}, #{password}, #{status}, #{isDeleted})
    </insert>
</mapper>
